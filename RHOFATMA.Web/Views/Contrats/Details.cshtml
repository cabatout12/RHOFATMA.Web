@model RHOFATMA.Web.Models.TblContrat
@{ ViewData["Title"] = "Details contrat"; }

<h1 class="h3 mb-3">Details contrat</h1>
<dl class="row">
    <dt class="col-sm-3">Employe</dt>
    <dd class="col-sm-9">@Model.IdEmployeNavigation.NomEmploye @Model.IdEmployeNavigation.PrenomEmploye</dd>
    <dt class="col-sm-3">Type contrat</dt>
    <dd class="col-sm-9">@Model.TypeContrat</dd>
    <dt class="col-sm-3">Date debut</dt>
    <dd class="col-sm-9">@Model.DateDebut.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Date fin</dt>
    <dd class="col-sm-9">@Model.DateFin?.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Salaire base</dt>
    <dd class="col-sm-9">@Model.SalaireBase.ToString("N2")</dd>
    <dt class="col-sm-3">Statut</dt>
    <dd class="col-sm-9">@Model.Statut</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.IdContrat" class="btn btn-primary">Modifier</a>
<a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
