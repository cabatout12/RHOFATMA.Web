@model RHOFATMA.Web.Models.TblDirection

@{
    ViewData["Title"] = "Supprimer une direction";
}

<h1 class="h3">Supprimer une direction</h1>
<p class="text-danger">Voulez-vous vraiment supprimer cette direction?</p>

<dl class="row">
    <dt class="col-sm-3">Nom direction</dt>
    <dd class="col-sm-9">@Model.NomDirection</dd>
</dl>

<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdDirection" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
