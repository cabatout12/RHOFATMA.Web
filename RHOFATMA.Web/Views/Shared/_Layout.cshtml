<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RHOFATMA.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RHOFATMA.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/ofatma-logo.jpg" asp-append-version="true" alt="OFATMA" class="navbar-logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="gestionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Gestion
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="gestionDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Bureaux" asp-action="Index">Bureau</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Directions" asp-action="Index">Direction</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Services" asp-action="Index">Service</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Sections" asp-action="Index">Section</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Formations" asp-action="Index">Formation</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Postes" asp-action="Index">Poste</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Users" asp-action="Index">User</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Roles" asp-action="Index">Role</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="AuditGenerales" asp-action="Index">AuditGeneral</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="RolePermissions" asp-action="Index">RolePermission</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="employeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Employe
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="employeDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Employes" asp-action="Index">Employe</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Primes" asp-action="Index">Prime</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Presences" asp-action="Index">Presence</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="AbsentRetards" asp-action="Index">AbsentRetard</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="DocumentEmployes" asp-action="Index">DocumentEmploye</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="congeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Conge
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="congeDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Conges" asp-action="Index">Conge</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Permissions" asp-action="Index">Permission</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="paieDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Paie
                            </a>
                            <ul class="dropdown-menu shadow-sm" aria-labelledby="paieDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Paies" asp-action="Index">Paie</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Deductions" asp-action="Index">Deduction</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Contrats" asp-action="Index">Contrat</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-3 px-lg-4">
        <main role="main" class="app-shell">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container-fluid px-3 px-lg-4">
            &copy; 2026 - RHOFATMA
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
