@model RHOFATMA.Web.Models.TblPrim
@{ ViewData["Title"] = "Modifier une prime"; }

<h1 class="h3 mb-3">Modifier une prime</h1>
<form asp-action="Edit" class="row g-3">
    <input type="hidden" asp-for="IdPrim" />
    <input type="hidden" asp-for="AjouterPar" />
    <input type="hidden" asp-for="AjouterLe" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="IdEmploye" class="form-label">Employe</label>
        <select asp-for="IdEmploye" class="form-select" asp-items="ViewBag.IdEmploye">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdEmploye" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="TypePrim" class="form-label">Type prime</label>
        <input asp-for="TypePrim" class="form-control" />
        <span asp-validation-for="TypePrim" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="MontantPrime" class="form-label">Montant</label>
        <input asp-for="MontantPrime" class="form-control" />
        <span asp-validation-for="MontantPrime" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DatePrim" class="form-label">Date</label>
        <input asp-for="DatePrim" class="form-control" type="date" />
        <span asp-validation-for="DatePrim" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdUser" class="form-label">User</label>
        <select asp-for="IdUser" class="form-select" asp-items="ViewBag.IdUser">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdUser" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
