@model RHOFATMA.Web.Models.TblPresence
@{ ViewData["Title"] = "Supprimer une presence"; }

<h1 class="h3">Supprimer une presence</h1>
<p class="text-danger">Voulez-vous vraiment supprimer cette presence?</p>
<dl class="row">
    <dt class="col-sm-3">Employe</dt>
    <dd class="col-sm-9">@Model.IdEmployeNavigation.NomEmploye @Model.IdEmployeNavigation.PrenomEmploye</dd>
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.DatePresence.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Statut</dt>
    <dd class="col-sm-9">@Model.Statut</dd>
</dl>
<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdPresence" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
