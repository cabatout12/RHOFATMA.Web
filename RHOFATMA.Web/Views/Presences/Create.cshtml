@model RHOFATMA.Web.Models.TblPresence
@{ ViewData["Title"] = "Ajouter une presence"; }

<h1 class="h3 mb-3">Ajouter une presence</h1>
<form asp-action="Create" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="IdEmploye" class="form-label">Employe</label>
        <select asp-for="IdEmploye" class="form-select" asp-items="ViewBag.IdEmploye">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdEmploye" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DatePresence" class="form-label">Date</label>
        <input asp-for="DatePresence" class="form-control" type="date" />
        <span asp-validation-for="DatePresence" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="HeureArrivee" class="form-label">Heure arrivee</label>
        <input asp-for="HeureArrivee" class="form-control" type="time" />
        <span asp-validation-for="HeureArrivee" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="HeureDepart" class="form-label">Heure depart</label>
        <input asp-for="HeureDepart" class="form-control" type="time" />
        <span asp-validation-for="HeureDepart" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Statut" class="form-label">Statut</label>
        <select asp-for="Statut" class="form-select">
            <option>Present</option>
            <option>Absent</option>
            <option>Retard</option>
            <option>Conge</option>
        </select>
        <span asp-validation-for="Statut" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Remarque" class="form-label">Remarque</label>
        <textarea asp-for="Remarque" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Remarque" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
