@model RHOFATMA.Web.Models.TblPermission
@{ ViewData["Title"] = "Supprimer une permission"; }

<h1 class="h3">Supprimer une permission</h1>
<p class="text-danger">Voulez-vous vraiment supprimer cette permission?</p>
<dl class="row">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.CodePermission</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.DescriptionPermission</dd>
</dl>
<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdPermission" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
