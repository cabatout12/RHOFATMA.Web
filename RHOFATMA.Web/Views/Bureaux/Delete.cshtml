@model RHOFATMA.Web.Models.TblBureau

@{
    ViewData["Title"] = "Supprimer un bureau";
}

<h1 class="h3">Supprimer un bureau</h1>
<p class="text-danger">Voulez-vous vraiment supprimer ce bureau?</p>

<dl class="row">
    <dt class="col-sm-3">Nom bureau</dt>
    <dd class="col-sm-9">@Model.NomBureau</dd>
    <dt class="col-sm-3">Adresse</dt>
    <dd class="col-sm-9">@Model.Adresse</dd>
</dl>

<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdBureau" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
