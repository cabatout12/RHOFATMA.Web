@model RHOFATMA.Web.Models.TblAuditGenerale
@{ ViewData["Title"] = "Ajouter un audit"; }

<h1 class="h3 mb-3">Ajouter un audit</h1>
<form asp-action="Create" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-5">
        <label asp-for="NomTable" class="form-label">Table</label>
        <input asp-for="NomTable" class="form-control" />
        <span asp-validation-for="NomTable" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="IdEnregistrement" class="form-label">Id enregistrement</label>
        <input asp-for="IdEnregistrement" class="form-control" />
        <span asp-validation-for="IdEnregistrement" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ActionType" class="form-label">Action</label>
        <select asp-for="ActionType" class="form-select">
            <option>INSERT</option>
            <option>UPDATE</option>
            <option>DELETE</option>
        </select>
        <span asp-validation-for="ActionType" class="text-danger"></span>
    </div>
    <div class="col-md-5">
        <label asp-for="ChampModifier" class="form-label">Champ modifie</label>
        <input asp-for="ChampModifier" class="form-control" />
        <span asp-validation-for="ChampModifier" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DateAction" class="form-label">Date action</label>
        <input asp-for="DateAction" class="form-control" type="datetime-local" />
        <span asp-validation-for="DateAction" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="UserId" class="form-label">User</label>
        <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ValeurAvant" class="form-label">Valeur avant</label>
        <textarea asp-for="ValeurAvant" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ValeurAvant" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="NouveauValeur" class="form-label">Nouvelle valeur</label>
        <textarea asp-for="NouveauValeur" class="form-control" rows="3"></textarea>
        <span asp-validation-for="NouveauValeur" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
