@model RHOFATMA.Web.Models.TblEmploye

@{
    ViewData["Title"] = "Supprimer un employe";
}

<h1 class="h3">Supprimer un employe</h1>
<p class="text-danger">Voulez-vous vraiment supprimer cet employe?</p>

<dl class="row">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.CodeEmploye</dd>
    <dt class="col-sm-3">Nom complet</dt>
    <dd class="col-sm-9">@Model.NomEmploye @Model.PrenomEmploye</dd>
    <dt class="col-sm-3">Poste</dt>
    <dd class="col-sm-9">@Model.IdPosteNavigation?.NomPoste</dd>
    <dt class="col-sm-3">Service</dt>
    <dd class="col-sm-9">@Model.IdServiceNavigation?.NomService</dd>
</dl>

<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdEmploye" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
