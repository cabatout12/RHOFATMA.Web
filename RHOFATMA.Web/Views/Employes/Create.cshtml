@model RHOFATMA.Web.Models.TblEmploye

@{
    ViewData["Title"] = "Ajouter un employe";
}

<h1 class="h3 mb-3">Ajouter un employe</h1>

<form asp-action="Create" class="row g-3">
    <partial name="_Form" model="Model" />
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
