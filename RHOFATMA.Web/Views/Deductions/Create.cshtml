@model RHOFATMA.Web.Models.TblDeduction
@{ ViewData["Title"] = "Ajouter une deduction"; }

<h1 class="h3 mb-3">Ajouter une deduction</h1>
<form asp-action="Create" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="IdEmploye" class="form-label">Employe</label>
        <select asp-for="IdEmploye" class="form-select" asp-items="ViewBag.IdEmploye">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdEmploye" class="text-danger"></span>
    </div>
    <div class="col-md-5">
        <label asp-for="TypeDeduction" class="form-label">Type deduction</label>
        <input asp-for="TypeDeduction" class="form-control" />
        <span asp-validation-for="TypeDeduction" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="MontantDeduction" class="form-label">Montant</label>
        <input asp-for="MontantDeduction" class="form-control" />
        <span asp-validation-for="MontantDeduction" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DateDeduction" class="form-label">Date</label>
        <input asp-for="DateDeduction" class="form-control" type="date" />
        <span asp-validation-for="DateDeduction" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Motif" class="form-label">Motif</label>
        <textarea asp-for="Motif" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Motif" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
