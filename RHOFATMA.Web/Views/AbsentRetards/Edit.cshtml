@model RHOFATMA.Web.Models.TblAbsentRetard
@{ ViewData["Title"] = "Modifier absence/retard"; }

<h1 class="h3 mb-3">Modifier absence/retard</h1>
<form asp-action="Edit" class="row g-3">
    <input type="hidden" asp-for="IdAbsentRetard" />
    <input type="hidden" asp-for="AjouterPar" />
    <input type="hidden" asp-for="AjouterLe" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="IdEmploye" class="form-label">Employe</label>
        <select asp-for="IdEmploye" class="form-select" asp-items="ViewBag.IdEmploye">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdEmploye" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DateRetard" class="form-label">Date</label>
        <input asp-for="DateRetard" class="form-control" type="date" />
        <span asp-validation-for="DateRetard" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Statut" class="form-label">Statut</label>
        <select asp-for="Statut" class="form-select">
            <option>Absent</option>
            <option>Retard</option>
        </select>
        <span asp-validation-for="Statut" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdUser" class="form-label">User</label>
        <select asp-for="IdUser" class="form-select" asp-items="ViewBag.IdUser">
            <option value="">-- Selectionner --</option>
        </select>
        <span asp-validation-for="IdUser" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Motif" class="form-label">Motif</label>
        <textarea asp-for="Motif" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Motif" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
