@model RHOFATMA.Web.Models.TblUser
@{ ViewData["Title"] = "Supprimer un user"; }

<h1 class="h3">Supprimer un user</h1>
<p class="text-danger">Voulez-vous vraiment supprimer ce user?</p>
<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.UserEmail</dd>
    <dt class="col-sm-3">Role</dt>
    <dd class="col-sm-9">@Model.IdRoleNavigation?.NomRole</dd>
    <dt class="col-sm-3">Statut</dt>
    <dd class="col-sm-9">@Model.Statut</dd>
</dl>
<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdUser" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
