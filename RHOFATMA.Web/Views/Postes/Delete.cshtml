@model RHOFATMA.Web.Models.TblPoste
@{ ViewData["Title"] = "Supprimer un poste"; }

<h1 class="h3">Supprimer un poste</h1>
<p class="text-danger">Voulez-vous vraiment supprimer ce poste?</p>
<dl class="row">
    <dt class="col-sm-3">Nom poste</dt>
    <dd class="col-sm-9">@Model.NomPoste</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.DescPoste</dd>
</dl>
<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdPoste" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
