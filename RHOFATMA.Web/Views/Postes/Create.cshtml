@model RHOFATMA.Web.Models.TblPoste
@{ ViewData["Title"] = "Ajouter un poste"; }

<h1 class="h3 mb-3">Ajouter un poste</h1>
<form asp-action="Create" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="NomPoste" class="form-label">Nom poste</label>
        <input asp-for="NomPoste" class="form-control" />
        <span asp-validation-for="NomPoste" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="DescPoste" class="form-label">Description</label>
        <textarea asp-for="DescPoste" class="form-control" rows="4"></textarea>
        <span asp-validation-for="DescPoste" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
