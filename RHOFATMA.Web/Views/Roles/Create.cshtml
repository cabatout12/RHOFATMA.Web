@model RHOFATMA.Web.Models.TblRole
@{ ViewData["Title"] = "Ajouter un role"; }

<h1 class="h3 mb-3">Ajouter un role</h1>
<form asp-action="Create" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="NomRole" class="form-label">Role</label>
        <input asp-for="NomRole" class="form-control" />
        <span asp-validation-for="NomRole" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="DescriptionRole" class="form-label">Description</label>
        <textarea asp-for="DescriptionRole" class="form-control" rows="4"></textarea>
        <span asp-validation-for="DescriptionRole" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
