@model RHOFATMA.Web.Models.TblFormation
@{ ViewData["Title"] = "Supprimer une formation"; }

<h1 class="h3">Supprimer une formation</h1>
<p class="text-danger">Voulez-vous vraiment supprimer cette formation?</p>
<dl class="row">
    <dt class="col-sm-3">Nom formation</dt>
    <dd class="col-sm-9">@Model.NomFormation</dd>
</dl>
<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="IdFormation" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
